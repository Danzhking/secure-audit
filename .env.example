# PostgreSQL
POSTGRES_USER=audit
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=auditdb

# RabbitMQ (логин/пароль для AMQP и веб-интерфейса)
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=CHANGE_ME

# Collector: список API-ключей через запятую и секрет для HMAC
COLLECTOR_API_KEYS=key-1,key-2
COLLECTOR_HMAC_SECRET=CHANGE_ME_min_32_characters

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# pgAdmin
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=CHANGE_ME

# API: секрет подписи JWT (не короче 32 символов)
JWT_SECRET=CHANGE_ME_must_be_at_least_32_characters
